APP_NAME=LaravelStarter
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8011

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14
PENNANT_STORE=database

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3309
DB_DATABASE=app
DB_ROOT_PASSWORD=demo-root-password
DB_USERNAME=app_user
DB_PASSWORD=demo-db-password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
FILE_STORAGE_DISK="${FILESYSTEM_DISK}"
QUEUE_CONNECTION=redis
QUEUE_NAME_DEFAULT=default
QUEUE_NAME_EMAIL=email
QUEUE_NAME_EXPORTS=exports

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6382

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=5
RATE_LIMIT_AUTH_PASSWORD_RESET_PER_MINUTE=3
RATE_LIMIT_AUTH_PASSWORD_UPDATE_PER_MINUTE=5
RATE_LIMIT_AUTH_VERIFICATION_SEND_PER_MINUTE=3
RATE_LIMIT_AUTH_VERIFICATION_VERIFY_PER_MINUTE=10
RATE_LIMIT_AUTH_SOCIAL_PER_MINUTE=20
RATE_LIMIT_ADMIN_SEARCH_PER_MINUTE=60
RATE_LIMIT_ADMIN_MUTATION_PER_MINUTE=30
RATE_LIMIT_ADMIN_IMPERSONATION_PER_MINUTE=10
RATE_LIMIT_SITE_AB_ASSIGN_PER_MINUTE=120
RATE_LIMIT_SITE_AB_EVENT_PER_MINUTE=120

REVERB_APP_ID=laravel-starter
REVERB_APP_KEY=laravel-starter-key
REVERB_APP_SECRET=laravel-starter-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
