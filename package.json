{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "laravel-starter",
    "private": true,
    "type": "module",
    "engines": {
        "node": "^24.0.0",
        "npm": "^11.0.0"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:all": "./scripts/run-dev.sh",
        "check": "./vendor/bin/pint --test && ./vendor/bin/phpstan analyse && npm run test:backend && npm run test:unit",
        "check:full": "npm run check",
        "lint": "eslint resources/js/**/*.ts",
        "lint:fix": "eslint resources/js/**/*.ts --fix",
        "test": "bash ./scripts/test.sh",
        "test:backend": "bash ./scripts/test.sh",
        "test:php": "SKIP_UNIT_TESTS=1 bash ./scripts/test.sh",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.0.3",
        "jsdom": "^29.0.0",
        "laravel-vite-plugin": "^2.0.0",
        "sass": "^1.98.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "chart.js": "^4.5.1"
    }
}
